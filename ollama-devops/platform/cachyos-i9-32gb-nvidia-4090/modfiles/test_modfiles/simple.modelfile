FROM qwen2.5:7b-instruct

#============================================================================
# Title:            simple.modelfile
# Description:      Simple test modfile for Qwen2.5 7B model with streamlined configuration
# Author:           Keverall
# Date:             2026-04-28
# Version:          1.0.0
# Hardware:         NVIDIA GeForce RTX 4090 (24GB VRAM)

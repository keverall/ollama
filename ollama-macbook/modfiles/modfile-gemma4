FROM gemma4:e4b

# ============================
# 1. Performance & Memory Tuning
# ============================
# 32k is the realistic limit for E4B on 24GB RAM. 
# For 64k, you MUST use gemma4:e2b instead.
PARAMETER num_ctx 32768
PARAMETER num_batch 512
PARAMETER num_thread 10

# Deterministic settings for DevOps precision
PARAMETER temperature 0.0
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.1

# ============================
# 2. DevOps-tuned System Prompt
# ============================
SYSTEM """
You are a senior DevOps engineer. Produce production-grade, secure Terraform, Kubernetes, and CI/CD code. 
Handle multi-file reasoning across large repositories. Follow DRY patterns and security hardening.
Style: Deterministic, low-temperature, accurate. Avoid verbosity.
"""

TEMPLATE """{{ .System }}
User request: {{ .Prompt }}
Answer:"""

# macOS (MacBook M4 24GB) Environment Configuration
# Copy this file to .env and customize for your setup

# Models to ensure are available (comma-separated)
DEFAULT_MODELS=llama3.2:1b,llama3.2:3b

# DevOps model for automation tasks (small, fast model)
DEVOPS_MODEL=llama3.2:1b

# Ollama performance settings (leave defaults for CPU)
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=3

# Qdrant port
QDRANT_PORT=6333
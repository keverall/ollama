# Linux (CachyOS i9-32GB NVIDIA 4090) Environment Configuration
# Copy this file to .env and customize for your setup

# Models to ensure are available (comma-separated, use GPU variants)
DEFAULT_MODELS=qwen2.5:7b-instruct,qwen2.5-coder:32b-gpu

# DevOps model for automation tasks (optional, leave empty to skip)
DEVOPS_MODEL=

# Ollama performance settings (optimized for GPU)
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=5
OLLAMA_GPU_LAYERS=50

# CUDA settings
CUDA_VISIBLE_DEVICES=0

# Qdrant port
QDRANT_PORT=6333
# ============================================================================
# Unified .env.example for Ollama Cross-Platform Scripts
# ============================================================================
# Copy this file to .env and customize for your environment:
#   cp .envexample .env
#
# Platform-specific settings are marked with [macos] and [linux/cachyos]
# The scripts auto-detect your platform and apply appropriate defaults.
#
# Manual platform override: export PLATFORM_OVERRIDE=macos|linux|cachyos
# ============================================================================

#----------------------------------------------------------------------------
# Ollama Configuration
#----------------------------------------------------------------------------
# Path to Ollama binary (optional, defaults to 'ollama' from PATH)
# OLLAMA_BIN="/usr/local/bin/ollama"
OLLAMA_BIN="ollama"

# Host binding for Ollama server (IPv6+IPv4 dual stack by default)
# [macos] Use [::]:11434 to allow both IPv4 and IPv6 connections
# [linux] Use 0.0.0.0:11434 for IPv4 only, or [::]:11434 for dual-stack
OLLAMA_HOST="[::]:11434"

# Port for Ollama API
OLLAMA_PORT="11434"

#----------------------------------------------------------------------------
# Performance Tuning (Platform-Specific Defaults Applied)
#----------------------------------------------------------------------------
# Number of parallel workers (based on CPU cores)
# [macos] Default: 24 (M4 Pro efficiency cores)
# [linux/cachyos] Default: 24 (i9-13900KS or similar)
OLLAMA_NUM_PARALLEL="24"

# Maximum number of models loaded in VRAM simultaneously
# [macos] Default: 2 (24GB RAM constraint)
# [linux/cachyos] Default: 2 (24GB VRAM constraint)
OLLAMA_MAX_LOADED_MODELS="2"

# [macos only] Flash attention optimization (M4 GPU)
# Set to 1 to enable, 0 to disable
OLLAMA_FLASH_ATTENTION="1"

# [macos only] KV cache quantization type for memory savings
# Options: q4_0, q4_1, q5_0, q5_1, q8_0
OLLAMA_KV_CACHE_TYPE="q4_0"

# [linux/cachyos only] GPU layers for model offloading
# Higher values = more layers on GPU (requires CUDA)
OLLAMA_GPU_LAYERS="50"

#----------------------------------------------------------------------------
# Model Configuration
#----------------------------------------------------------------------------
# Comma-separated list of models to ensure are present
# [macos] Typical: nomic-embed-text,qwen2.5-coder:14b
# [linux/cachyos] Typical: qwen2.5:72b-instruct,qwen2.5:7b-instruct,nomic-embed-text:latest
DEFAULT_MODELS="nomic-embed-text,qwen2.5-coder:14b"

# Custom DevOps model name (built from modfile)
# [macos] qwen-devops or gemma4-devops
# [linux/cachyos] Leave empty unless using custom models
DEVOPS_MODEL="qwen-devops"

#----------------------------------------------------------------------------
# Qdrant Configuration
#----------------------------------------------------------------------------
QDRANT_PORT="6333"
QDRANT_GRPC_PORT="6334"

#----------------------------------------------------------------------------
# Advanced Configuration (Optional)
#----------------------------------------------------------------------------
# Override automatic platform detection
# Set to: auto, macos, cachyos, linux
# PLATFORM_OVERRIDE="auto"

# Override project root (useful for testing)
# PROJECT_ROOT="/path/to/ollama"

# Custom log directory
# LOG_DIR="/path/to/logs"

# NVIDIA GPU visibility (Linux with multiple GPUs)
# CUDA_VISIBLE_DEVICES="0"

#----------------------------------------------------------------------------
# MacBook-Specific (M4 Pro 24GB)
#----------------------------------------------------------------------------
# These are typically NOT needed as they're set automatically for macos:
# OLLAMA_FLASH_ATTENTION=1
# OLLAMA_KV_CACHE_TYPE=q4_0

# Local models directory (optional)
# OLLAMA_MODELS="${HOME}/.ollama/models"

#----------------------------------------------------------------------------
# CachyOS/Linux-Specific (RTX 4090 24GB)
#----------------------------------------------------------------------------
# These are typically NOT needed as they're set automatically for linux:
# OLLAMA_GPU_LAYERS=50

# Systemd service name (if installed)
# OLLAMA_SERVICE_NAME="ollama"

#----------------------------------------------------------------------------
# Notes
#----------------------------------------------------------------------------
# 1. After editing this file, run: source .env (or restart your shell)
# 2. For MacBook M4 Pro: use models that fit in 24GB unified memory
# 3. For CachyOS RTX 4090: use GPU-optimized modfiles for 24GB VRAM
# 4. Docker must be running for Qdrant to start
# 5. On Linux, sudo may be required for systemctl operations
